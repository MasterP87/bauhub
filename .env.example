# BauHub Umgebungsvariablen
# Kopieren nach .env.local (lokal) oder in Vercel/Netlify Dashboard eintragen

# ============================================================
# SUPABASE (https://supabase.com → Ihr Projekt → Settings → API)
# ============================================================
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================
# STRIPE (https://dashboard.stripe.com → Developers → API Keys)
# ============================================================
STRIPE_PUBLIC_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PREMIUM_PRICE_ID=price_...
STRIPE_PLATFORM_ACCOUNT=acct_...

# ============================================================
# KI (https://console.anthropic.com)
# ============================================================
ANTHROPIC_API_KEY=sk-ant-api03-...

# ============================================================
# n8n (auf Oracle Cloud installiert)
# ============================================================
N8N_HOST=n8n.yourdomain.com
N8N_USER=admin
N8N_PASSWORD=change_me_secure_password_123
N8N_ENCRYPTION_KEY=generate_32_random_chars_here_now

# Webhook-URLs (nach n8n Installation eintragen)
N8N_WEBHOOK_USER_REGISTER=https://n8n.yourdomain.com/webhook/user-register
N8N_WEBHOOK_USER_VERIFY=https://n8n.yourdomain.com/webhook/user-verify
N8N_WEBHOOK_MATCHING=https://n8n.yourdomain.com/webhook/matching
N8N_WEBHOOK_MATCHING_EMAIL=https://n8n.yourdomain.com/webhook/matching-email
N8N_WEBHOOK_APPLICATION=https://n8n.yourdomain.com/webhook/application
N8N_WEBHOOK_MATCH_CONFIRM=https://n8n.yourdomain.com/webhook/match-confirm
N8N_WEBHOOK_FORUM_MODERATE=https://n8n.yourdomain.com/webhook/forum-moderate
N8N_WEBHOOK_RESOURCES=https://n8n.yourdomain.com/webhook/resource-new
N8N_WEBHOOK_MONTHLY_REPORT=https://n8n.yourdomain.com/webhook/monthly-report

# ============================================================
# E-MAIL (z.B. Brevo Free Tier: 300 E-Mails/Tag kostenlos)
# https://brevo.com → SMTP & API → SMTP
# ============================================================
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_brevo_login@example.com
SMTP_PASS=your_brevo_smtp_key
SMTP_FROM=noreply@yourdomain.com

# ============================================================
# ALLGEMEIN
# ============================================================
SITE_URL=https://bauhub.vercel.app
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_API_KEY=generate_random_key_here

# ============================================================
# SUPABASE EDGE FUNCTIONS (werden in Supabase Dashboard gesetzt)
# Dashboard → Edge Functions → Secrets
# ============================================================
# Diese Variablen müssen in Supabase als Secrets hinterlegt werden:
# - SUPABASE_SERVICE_ROLE_KEY (automatisch vorhanden)
# - STRIPE_SECRET_KEY
# - ANTHROPIC_API_KEY
# - N8N_WEBHOOK_USER_REGISTER
# - N8N_WEBHOOK_USER_VERIFY
# - N8N_WEBHOOK_MATCHING
# - N8N_WEBHOOK_MATCHING_EMAIL
# - N8N_WEBHOOK_APPLICATION
# - N8N_WEBHOOK_MATCH_CONFIRM
# - N8N_WEBHOOK_FORUM_MODERATE
# - N8N_WEBHOOK_RESOURCES
# - STRIPE_PREMIUM_PRICE_ID
# - SITE_URL
# - ADMIN_API_KEY
